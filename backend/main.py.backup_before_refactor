# 数据库连接池
db_pool: Optional[asyncpg.Pool] = None

# 请求统计
request_stats: Dict[str, int] = {"total": 0, "errors": 0}


async def init_db_pool() -> asyncpg.Pool:
    """初始化数据库连接池"""
    global db_pool
    if db_pool is None:
        database_url = os.getenv("DATABASE_URL")
        if not database_url:
            raise ValueError(
                "DATABASE_URL environment variable is required. "
                "Please set it before starting the application."
            )
        db_pool = await asyncpg.create_pool(
            database_url,
            min_size=2,
            max_size=10,
            command_timeout=60
        )
        logger.info("Database pool initialized")
    return db_pool


async def close_db_pool() -> None:
    """关闭数据库连接池"""
    global db_pool
    if db_pool:
        await db_pool.close()
        db_pool = None
        logger.info("Database pool closed")


@asynccontextmanager
async def lifespan(app: FastAPI):
    """应用生命周期管理"""
    # 启动时初始化
    await init_db_pool()

    # 初始化缓存系统
    from config import Config
    await setup_cache(
        redis_url=Config.REDIS_URL,
        config=None  # 使用默认配置
    )
    logger.info("Cache system initialized")

    # P5: 初始化领域系统
    pool = await init_db_pool()
    await setup_domains(pool)
    logger.info("Domains initialized")

    # P5: 初始化健康检查
    health_checker = get_health_checker()

    async def check_database():
        """数据库健康检查包装"""
        from monitoring.health import database_health_check
        return await database_health_check(pool)

    health_checker.register("database", check_database, interval=30)
    await health_checker.start_background_checks()
    logger.info("Health checks started")

    # P5: 初始化指标收集
    metrics = get_metrics_collector()
    metrics.increment_counter("app_startup")
    logger.info("Metrics initialized")

    logger.info("Application started (P5: System Integration)")
    yield
    # 关闭时清理
    await close_db_pool()

    # P5: 清理领域系统
    registry = get_registry()
    await registry.shutdown_all()

    # P5: 停止健康检查
    await health_checker.stop_background_checks()

    logger.info("Application shutdown")


