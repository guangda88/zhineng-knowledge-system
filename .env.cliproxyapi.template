# CLIProxyAPI Environment Variables Template
# Copy this file to .env.cliproxyapi and fill in your API keys
#
# Usage:
#   cp .env.cliproxyapi.template .env.cliproxyapi
#   # Edit .env.cliproxyapi with your API keys
#   docker-compose -f docker-compose.yml -f docker-compose.cli-proxy.yml --env-file .env.cliproxyapi up -d

# ============================================================================
# AI Provider API Keys
# ============================================================================

# DeepSeek API (https://platform.deepseek.com/)
# Primary model for general chat - cost-effective
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Claude API (https://console.anthropic.com/)
# High-quality reasoning and coding
CLAUDE_API_KEY=your_claude_api_key_here

# Gemini API (https://aistudio.google.com/app/apikey)
# Multimodal and fast responses
GEMINI_API_KEY=your_gemini_api_key_here

# Qwen API (https://dashscope.aliyun.com/)
# Optimized for Chinese language
QWEN_API_KEY=your_qwen_api_key_here

# ============================================================================
# Optional: OAuth Configuration
# ============================================================================

# GitHub OAuth (for Claude Code integration)
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (for Gemini CLI integration)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Secret (if using JWT authentication)
# Generate a strong random string in production!
JWT_SECRET=lingzhi-default-secret-change-in-production

# ============================================================================
# Notes
# ============================================================================

# Minimum Required Keys (for basic functionality):
#   - DEEPSEEK_API_KEY (recommended as primary model)
#   - At least one of: CLAUDE_API_KEY, GEMINI_API_KEY, QWEN_API_KEY
#
# Getting API Keys:
# 1. DeepSeek: https://platform.deepseek.com/ -> API Keys
# 2. Claude: https://console.anthropic.com/ -> API Keys
# 3. Gemini: https://aistudio.google.com/app/apikey
# 4. Qwen: https://dashscope.aliyun.com/ -> API-KEY管理
#
# Security Best Practices:
# - Never commit .env files to git
# - Use strong, unique API keys
# - Rotate keys periodically
# - Monitor API usage
# - Set up billing alerts
