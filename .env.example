# 智能知识系统 - 环境变量配置

# ==================== 环境配置 ====================
# 运行环境: development, staging, production
# 生产环境必须设置为 production，以启用严格安全检查
ENVIRONMENT=development

# CORS 允许的跨域来源（多个用逗号分隔）
# 生产环境必须设置此变量，否则服务将拒绝启动
# 示例: ALLOWED_ORIGINS=https://example.com,https://api.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8008,http://localhost:8000

# ==================== 数据库配置 ====================
POSTGRES_PASSWORD=zhineng_secure_2024
REDIS_PASSWORD=zhineng_redis_2024

# ==================== MinIO 配置 ====================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123

# ==================== 监控配置 ====================
GRAFANA_PASSWORD=admin123

# ==================== AI API 配置 ====================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# ==================== Bridge 配置 ====================
BRIDGE_WS_HOST=relay-server
BRIDGE_WS_PORT=8765
