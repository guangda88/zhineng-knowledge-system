# 智能知识系统 - 环境变量配置示例
# 复制此文件为 .env 并填入真实值
#
# ⚠️ 重要安全提示：
# 1. 所有密码都是必需的，没有默认值
# 2. 使用强密码（至少16个字符，包含大小写字母、数字、特殊字符）
# 3. 不要提交 .env 文件到版本控制
# 4. 定期轮换密码

# ========== 数据库配置（必需） ==========
# ⚠️ 严禁硬编码密码，必须通过环境变量设置
# ⚠️ 生产环境启动前必须设置此密码
DATABASE_URL=postgresql://zhineng:YOUR_SECURE_PASSWORD@localhost:5432/zhineng_kb
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# ========== Redis配置（必需） ==========
# ⚠️ 生产环境启动前必须设置此密码
REDIS_URL=redis://:YOUR_SECURE_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# ========== API配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=production

# ========== 安全配置 ==========
# ⚠️ 生产环境必须设置强密钥
SECRET_KEY=your-secret-key-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# ========== CORS配置（安全） ==========
# 仅允许白名单来源，禁止使用 ["*"]
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001

# ========== 速率限制配置 ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ========== 外部API密钥 ==========
DEEPSEEK_API_KEY=your_deepseek_api_key
# BGE_API_KEY 已弃用 - 使用本地嵌入服务
# BGE_API_KEY=your_bge_api_key
OPENAI_API_KEY=your_openai_api_key

# ========== 本地嵌入服务配置 ==========
# BGE-M3 嵌入服务地址（Docker内部网络）
EMBEDDING_SERVICE_URL=http://embedding:8001

# ========== 监控配置 ==========
# ⚠️ 生产环境启动前必须设置此密码（Grafana管理员密码）
GRAFANA_PASSWORD=YOUR_SECURE_GRAFANA_PASSWORD

# ========== 日志配置 ==========
LOG_LEVEL=INFO

# ========== LingFlow 搜索引擎配置 ==========
LINGFLOW_ENABLED=true
LINGFLOW_DEFAULT_MODE=fulltext
LINGFLOW_SEARCH_TIMEOUT=60
LINGFLOW_SNIPPET_LENGTH=300
LINGFLOW_UNIFIED_PAGE_SIZE=20
