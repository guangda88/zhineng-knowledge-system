# 生产环境配置示例
# 复制此文件为 .env 并填入真实值

# ========== 数据库配置 ==========
# ⚠️  请使用强密码！
DATABASE_URL=postgresql://zhineng:CHANGE_THIS_PASSWORD@localhost:5432/zhineng_kb
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# ========== Redis配置 ==========
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ========== 安全配置 ==========
# ⚠️ 必须设置为至少32字符的随机字符串
SECRET_KEY=$(openssl rand -hex 32)
JWT_PRIVATE_KEY_PATH=/home/ai/zhineng-knowledge-system/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/home/ai/zhineng-knowledge-system/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_EXPIRATION=3600

# ========== CORS配置（生产环境） ==========
# ⚠️ 仅添加信任的域名
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========== 速率限制配置 ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ========== 外部API密钥 ==========
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# BGE_API_KEY 已弃用 - 使用本地嵌入服务
# BGE_API_KEY=your_bge_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ========== 本地嵌入服务配置 ==========
# BGE-M3 嵌入服务地址（Docker内部网络）
EMBEDDING_SERVICE_URL=http://embedding:8001

# ========== 应用配置 ==========
ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ========== 监控配置 ==========
GRAFANA_PASSWORD=your_grafana_password_here
